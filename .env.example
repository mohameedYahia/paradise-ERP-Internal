# ========================================
# الخيار الأول: للمستخدمين العاديين (@gmail.com) - موصى به
# ========================================
# استخدم هذا الخيار إذا كان حسابك مجاني وليس لديك Google Workspace
# لعمل ذلك، قم باستخراج هذه المفاتيح من Google Cloud و OAuth 2.0 Playground
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=

# ========================================
# الخيار الثاني: للشركات ومساحات العمل (Google Workspace Shared Drives)
# ========================================
# (لا يعمل هذا الخيار إذا كان المجلد في حسابك الشخصي المجاني)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
